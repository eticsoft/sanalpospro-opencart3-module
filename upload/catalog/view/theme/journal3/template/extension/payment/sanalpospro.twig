<div class="payment-container">
    <div id="payment-iframe-container" class="spp-iframe-inline">
        <div class="spp-iframe-content">
            <iframe id="spp-payment-iframe" src="about:blank" class="spp-payment-iframe"></iframe>
            <div id="spp-iframe-loading" class="spp-iframe-loading">
                <i class="fa-solid fa-circle-notch fa-spin"></i>
            </div>
        </div>
        <div id="spp-iframe-error" class="alert alert-danger d-none"></div>
    </div>
</div>
{# <script src="https://code.jquery.com/jquery-3.7.1.js"></script> #}
<script>
    const orderConfirmationUrl = '{{ order_confirmation_url }}';
    const SELECTORS = {
        PAYMENT_IFRAME: '#spp-payment-iframe',
        PAYMENT_IFRAME_LOADING: '#spp-iframe-loading',
        PAYMENT_IFRAME_ERROR: '#spp-iframe-error',
        PAYMENT_CONTAINER: '.payment-container'
    };

    class PaymentHandler {
        constructor(requestUrl) {
            this.requestUrl = requestUrl;
            this.handlePaymentRequest();
        }

        async handlePaymentRequest() {
            try {
                $(SELECTORS.PAYMENT_IFRAME_ERROR).addClass('d-none').html('');
                $(SELECTORS.PAYMENT_IFRAME_LOADING).removeClass('d-none');

                $.ajax({
                    url: this.requestUrl,
                    type: 'POST',
                    data: {
                        iapi_action: 'createPaymentLink',
                        iapi_params: JSON.stringify(this.getFormData($('#form-register'))),
                        iapi_xfvv: '{{xfvv}}'
                    },
                    success: (response) => {
                        this.handlePaymentResponse(response);
                    },
                    error: (error) => {
                        this.handlePaymentResponse(error.responseJSON);
                        console.error('Payment request failed:', error);
                    }
                });
            } catch (error) {
                console.error('Payment request failed:', error);
            }
        }

        getFormData(form){
            var unindexed_array = form.serializeArray();
            var indexed_array = {};

            $.map(unindexed_array, function(n, i){
                indexed_array[n['name']] = n['value'];
             });

            return indexed_array;
        }

        handlePaymentResponse(response) {
            if (response && response.status === "success") {
                this.loadPaymentIframe(response.data.payment_link);
            } else {
                let message = (response && response.message) ? response.message : 'Payment request failed';
                if (response && response.details && Array.isArray(response.details)) {
                    message += '<br>' + response.details.join('<br>');
                }
                this.showError(message);
            }
        }

        loadPaymentIframe(paymentLink) {
            const iframe = document.querySelector(SELECTORS.PAYMENT_IFRAME);
            if (!iframe) {
                return;
            }
            iframe.addEventListener('load', () => {
                $(SELECTORS.PAYMENT_IFRAME_LOADING).addClass('d-none');
            }, { once: true });
            iframe.src = paymentLink;
        }

        showError(errorMessage) {
            $(SELECTORS.PAYMENT_IFRAME_LOADING).addClass('d-none');
            $(SELECTORS.PAYMENT_IFRAME_ERROR).removeClass('d-none').html(errorMessage);
        }
    }

    // Initialize the payment handler immediately
    var paythorPayment = new PaymentHandler('{{ request_url }}');

    // list post message
    window.addEventListener('message', function (event) {
        if (event.origin === 'https://pay.paythor.com' || event.origin === 'https://dev-pay.paythor.com') {
            if(event.data.tdsForm && event.data.form_selector_id === 'three_d_form') {
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = event.data.tdsForm;
                const form = tempDiv.firstElementChild;
                document.body.appendChild(form);
                form.submit();
            }


            if (event.data.isSuccess) {
                // ESC tuşunu devre dışı bırak
                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' || e.keyCode === 27 ||
                        e.key === 'F5' ||
                        (e.ctrlKey && e.key === 'r') ||
                        (e.ctrlKey && e.shiftKey && e.key === 'r') ||
                        (e.metaKey && e.key === 'r') ||  // Mac için Command + R
                        (e.metaKey && e.shiftKey && e.key === 'r')  // Mac için Command + Shift + R
                    ) {
                        e.preventDefault();
                        return false;
                    }
                });

                window.onbeforeunload = function() {
                    return "Ödeme işlemi devam ediyor.";
                };

                $.ajax({
                    url: '{{request_url}}',
                    type: 'POST',
                    data: {
                        iapi_action: 'confirmOrder',
                        iapi_xfvv: '{{xfvv}}',
                        iapi_params: JSON.stringify({ process_token: event.data.processID })
                    },
                    success: (response) => {
                        if (response.data.redirect_url) {
                            setTimeout(() => {
                                window.onbeforeunload = null;
                                window.location.href = response.data.redirect_url;
                            }, 500);
                        }
                    },
                    error: (error) => {
                        window.onbeforeunload = null;
                        console.error('Payment request failed:', error);
                    }
                });
            }
        }
    }, false);

    // Add styles for the inline iframe
    const styles = `
    .payment-container {
        width: 100%;
        max-width: 100%;
    }

    .popup-container,
    .popup-container .popup-content,
    .popup-container .popup-inner {
        max-width: 1400px !important;
        width: 95vw !important;
    }

    .spp-iframe-inline {
        width: 100%;
        margin-top: 15px;
    }

    .spp-iframe-content {
        position: relative;
        width: 100%;
        height: 85vh;
        min-height: 700px;
    }

    .spp-payment-iframe {
        width: 100%;
        height: 100%;
        border: none;
    }

    .spp-iframe-loading {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        font-size: 32px;
        color: #6c757d;
    }

    .spp-iframe-loading i {
        animation: spin 1s linear infinite;
    }

    .alert-danger {
        color: #721c24;
        background-color: #f8d7da;
        border-color: #f5c6cb;
        padding: 0.75rem 1.25rem;
        margin-top: 1rem;
        border: 1px solid transparent;
        border-radius: 0.25rem;
    }

    .d-none {
        display: none !important;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    `;

    // Add styles to the document
    const styleSheet = document.createElement('style');
    styleSheet.textContent = styles;
    document.head.appendChild(styleSheet);
</script>
